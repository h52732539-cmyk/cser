+def _parse_int_list(raw: str) -> list[int]:
+    vals = []
+    for part in raw.split(","):
+        part = part.strip()
+        if not part:
+            continue
+        vals.append(int(part))
+    if not vals:
+        raise ValueError("list must contain at least one integer")
+    return vals
+
